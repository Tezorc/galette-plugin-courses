{% extends "page.html.twig" %}

{% block content %}

{# Phase 47.2 : avertissement eligibilite (cotisation / actif / statut "Non membre")
   pour le parent et chacun des enfants. Les libelles sont pre-formates cote PHP. #}
{% if ineligible_members|length > 0 %}
    <div class="ui orange message">
        <i class="exclamation triangle icon" aria-hidden="true"></i>
        <p>{{ _T("Registration will not be possible for the following member(s) until the situation is fixed:", "courses") }}</p>
        <ul>
            {% for reason in ineligible_members %}
                <li>{{ reason }}</li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

{# Avertissement changement de groupe : inscriptions futures sur un evenement
   dont l'adherent ne fait plus partie du groupe requis #}
{% if out_of_group_regs|length > 0 %}
    <div class="ui orange message">
        <i class="exclamation triangle icon" aria-hidden="true"></i>
        {{ _Tn("%d registration is on an event you no longer have access to (group membership changed). You can unregister from the marked card below.", "%d registrations are on events you no longer have access to (group membership changed). You can unregister from the marked cards below.", out_of_group_regs|length, "courses")|format(out_of_group_regs|length) }}
    </div>
{% endif %}

{# =========================================================
   Préparer les données
   ========================================================= #}
{% set upcoming_active = [] %}
{% set upcoming_cancelled = [] %}
{% set past = [] %}
{% for reg in registrations %}
    {% set s = sessions[reg.getSessionId()] %}
    {% if s.getSessionDate() >= "now"|date("Y-m-d") %}
        {% if s.getStatus() == 'cancelled' %}
            {% set upcoming_cancelled = upcoming_cancelled|merge([reg]) %}
        {% else %}
            {% set upcoming_active = upcoming_active|merge([reg]) %}
        {% endif %}
    {% else %}
        {% set past = past|merge([reg]) %}
    {% endif %}
{% endfor %}

{# Grouper les prochaines séances : next_group = toutes celles à la date la plus proche, rest_group = le reste #}
{% set next_group = [] %}
{% set rest_group = [] %}
{% if upcoming_active|length > 0 %}
    {% set next_date = sessions[(upcoming_active|first).getSessionId()].getSessionDate() %}
    {% for reg in upcoming_active %}
        {% if sessions[reg.getSessionId()].getSessionDate() == next_date %}
            {% set next_group = next_group|merge([reg]) %}
        {% else %}
            {% set rest_group = rest_group|merge([reg]) %}
        {% endif %}
    {% endfor %}
{% endif %}

{# Compter les séances disponibles : doit correspondre EXACTEMENT au
   filtre de la boucle de cartes ci-dessous (déjà inscrit OU plus aucune
   action possible -> carte non rendue, donc non comptée). #}
{% set browse_count = 0 %}
{% for s in available_sessions %}
    {% set _sid = s.getId() %}
    {% set _already = _sid in registered_session_ids %}
    {% set _no_action_left = not browse_can_self_register[_sid] and not browse_on_waitlist[_sid] and (browse_eligible_children[_sid] is not defined or browse_eligible_children[_sid]|length == 0) %}
    {% if not _already and not _no_action_left %}
        {% set browse_count = browse_count + 1 %}
    {% endif %}
{% endfor %}

{# =========================================================
   Onglets
   ========================================================= #}
<div class="ui top attached tabular menu" id="my-sessions-tabs">
    <a class="item active" data-tab="browse">
        <i class="search icon" aria-hidden="true"></i>
        <span class="courses-tab-text">{{ _T("Find a session", "courses") }}</span>
        <span id="browse-count-badge" class="ui teal circular label" style="margin-left:.4em;{% if browse_count == 0 %}display:none;{% endif %}">{{ browse_count }}</span>
    </a>
    <a class="item" data-tab="mine">
        <i class="calendar check icon" aria-hidden="true"></i>
        <span class="courses-tab-text">{{ _T("My registrations", "courses") }}</span>
        {% if upcoming_active|length > 0 %}
            <span class="ui green circular label" style="margin-left:.4em">{{ upcoming_active|length }}</span>
        {% endif %}
    </a>
</div>

{# =========================================================
   ONGLET 1 — S'inscrire
   ========================================================= #}
<div class="ui bottom attached tab segment active" data-tab="browse" style="padding:1em 0; border:none; box-shadow:none;">

    {# Phase 47.2: le bandeau d'eligibilite en tete du block content rend ce
       message redondant. Le flag member_is_up2date est conserve plus bas pour
       desactiver les boutons "S'inscrire" sur chaque carte. #}

    {% if available_sessions|length > 0 %}
    {# Filtres dynamiques (JS, sans rechargement)
       NOTE: les <select> sont volontairement des selects HTML natifs (pas
       de class="ui search dropdown") pour eviter les problemes de timing
       et de synchronisation de Fomantic UI. Les evenements `change`
       natifs sont fiables sur tous les navigateurs / mobiles. #}
    <div class="ui secondary yellow segment courses-browse-filters" style="margin-bottom:1em;">
        <div class="ui form">
            <div class="three fields" style="margin-bottom:.5em;">
                <div class="field">
                    <label for="browse_type_filter">{{ _T("Type", "courses") }}</label>
                    <select id="browse_type_filter" class="courses-native-select">
                        <option value="">{{ _T("All types", "courses") }}</option>
                        {% for type in browse_event_types %}
                            <option value="{{ type.getId() }}">{{ type.getLabel() }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="browse_name_filter">{{ _T("Activity", "courses") }}</label>
                    <select id="browse_name_filter" class="courses-native-select">
                        <option value="">{{ _T("All activities", "courses") }}</option>
                        {% for item in browse_available_names %}
                            <option value="{{ item.name }}" data-type-id="{{ item.type_id }}">{{ item.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="browse_date_from">{{ _T("From", "courses") }}</label>
                    <input type="date" id="browse_date_from" value="{{ "now"|date("Y-m-d") }}"/>
                </div>
            </div>
            <div class="courses-filter-actions">
                <button type="button" id="browse_apply_filter" class="ui small labeled icon primary button">
                    <i class="search icon" aria-hidden="true"></i>
                    {{ _T("Filter", "courses") }}
                </button>
                <button type="button" id="browse_clear_filter" class="ui small labeled icon button">
                    <i class="trash alt red icon" aria-hidden="true"></i>
                    {{ _T("Clear filter", "courses") }}
                </button>
            </div>
        </div>
    </div>
    {% endif %}

    <div id="browse-no-results" class="ui info message" style="display:none;">
        <i class="search icon" aria-hidden="true"></i>
        {{ _T("No session matches your filters.", "courses") }}
    </div>

    {% if available_sessions|length == 0 %}
        <div class="ui info message">
            <i class="calendar outline icon" aria-hidden="true"></i>
            {{ _T("No upcoming session available.", "courses") }}
        </div>
    {% else %}
        <div class="ui stackable three column grid courses-cards-grid" id="browse-cards-grid">
        {% for s in available_sessions %}
            {% set sid = s.getId() %}
            {% set ev = browse_events[s.getEventId()] %}
            {% set already = sid in registered_session_ids %}
            {% set on_wl = browse_on_waitlist[sid] %}
            {% set has_instr = browse_has_instructor[sid] %}

            {% set no_action_left = not browse_can_self_register[sid] and not browse_on_waitlist[sid] and (browse_eligible_children[sid] is not defined or browse_eligible_children[sid]|length == 0) %}
            {% if not already and not no_action_left %}
            <div class="column courses-browse-card-col"
                 data-type-id="{{ ev.getTypeId() }}"
                 data-event-name="{{ ev.getName() }}"
                 data-date="{{ s.getSessionDate() }}">
                <div class="ui fluid card courses-card">
                    <div class="content">
                        {# Badge statut #}
                        <div class="right floated meta">
                            {% if on_wl %}
                                <span class="ui blue label">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Waitlist", "courses") }}
                                </span>
                            {% elseif not has_instr and not ev.isRegistrationAllowedWithoutInstructor() %}
                                <span class="ui orange label">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Awaiting instructor", "courses") }}
                                </span>
                            {% elseif s.isFull() %}
                                <span class="ui orange label">{{ _T("Full", "courses") }}</span>
                            {% else %}
                                <span class="ui green label">{{ _T("Open", "courses") }}</span>
                            {% endif %}
                        </div>

                        <div class="header">{{ ev.getName() }}</div>

                        <div class="meta">
                            <i class="calendar icon" aria-hidden="true"></i>
                            <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                            <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                            &nbsp;&middot;&nbsp;
                            {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                        </div>
                        {% if ev.getLocation() %}
                            <div class="meta">
                                <i class="map pin icon" aria-hidden="true"></i>
                                {{ ev.getLocation() }}
                            </div>
                        {% endif %}
                        {% if has_instr and browse_instructor_names[sid] is defined %}
                            <div class="meta">
                                <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                {{ browse_instructor_names[sid] }}
                            </div>
                        {% endif %}
                    </div>

                    {# Jauge capacité #}
                    {% if s.getMaxCapacity() %}
                        <div class="content">
                            <div class="ui tiny progress{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                            </div>
                        </div>
                    {% endif %}

                    {# Actions #}
                    <div class="extra content">
                        {% if on_wl %}
                            {# Sur liste d'attente #}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny button">
                                <i class="eye icon" aria-hidden="true"></i>
                                {{ _T("Details", "courses") }}
                            </a>
                        {% elseif not has_instr and not ev.isRegistrationAllowedWithoutInstructor() %}
                            {# Pas d'instructeur et inscription bloquee par defaut — pas d'inscription possible #}
                            <span class="ui tiny orange label">
                                <i class="exclamation triangle icon" aria-hidden="true"></i>
                                {{ _T("No instructor", "courses") }}
                            </span>
                        {% elseif not member_is_up2date %}
                            {# Cotisation non à jour #}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny button">
                                {{ _T("Details", "courses") }}
                            </a>
                        {% elseif s.isFull() %}
                            {# Session complète : liste d'attente pour le membre lui-même #}
                            {% if browse_can_self_register[sid] %}
                                <form action="{{ url_for("coursesDoWaitlist", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <button type="submit" class="ui tiny labeled icon blue button">
                                        <i class="clock icon" aria-hidden="true"></i>
                                        {{ _T("Join waitlist", "courses") }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% endif %}
                            {# Liste d'attente enfants : via la fiche séance #}
                            {% if browse_eligible_children[sid] is defined and browse_eligible_children[sid]|length > 0 %}
                                <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny labeled icon teal button">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                            {% endif %}
                            {% if not browse_can_self_register[sid] and (browse_eligible_children[sid] is not defined or browse_eligible_children[sid]|length == 0) %}
                                <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                                    {{ _T("Details", "courses") }}
                                </a>
                            {% endif %}
                        {% else %}
                            {% set self_count = browse_can_self_register[sid] ? 1 : 0 %}
                            {% set children_count = (browse_eligible_children[sid] is defined) ? browse_eligible_children[sid]|length : 0 %}
                            {% set total_options = self_count + children_count %}

                            {% if total_options == 1 and browse_can_self_register[sid] %}
                                {# Seule option : le membre lui-meme — on affiche le nickname (nom du chien) si dispo #}
                                {% set self_nick = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                <form action="{{ url_for("coursesDoRegister", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <button type="submit" class="ui tiny labeled icon green button">
                                        <i class="user plus icon" aria-hidden="true"></i>
                                        {{ self_nick ? self_nick : _T("Register", "courses") }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif total_options == 1 %}
                                {# Seule option : un seul enfant — POST direct, bouton porte son nom #}
                                {% set only_child_id = browse_eligible_children[sid]|keys|first %}
                                {% set only_child_info = browse_eligible_children[sid][only_child_id] %}
                                <form action="{{ url_for("coursesDoParentRegister", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <input type="hidden" name="member_id" value="{{ only_child_id }}"/>
                                    <button type="submit" class="ui tiny labeled icon teal button">
                                        <i class="user plus icon" aria-hidden="true"></i>
                                        {{ only_child_info.nickname ? only_child_info.nickname : only_child_info.name }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif total_options >= 2 %}
                                {# Plusieurs options : un seul bouton dropdown qui liste les choix #}
                                <div class="ui simple dropdown tiny labeled icon teal button">
                                    <i class="user plus icon" aria-hidden="true"></i>
                                    <span class="text">{{ _T("Register", "courses") }}</span>
                                    <i class="dropdown icon" aria-hidden="true"></i>
                                    <div class="menu">
                                        {% if browse_can_self_register[sid] %}
                                            {% set self_nick_drop = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                            <a class="item courses-register-trigger" data-target="register-self-{{ sid }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ self_nick_drop ? self_nick_drop : _T("Myself", "courses") }}
                                            </a>
                                        {% endif %}
                                        {% for child_id, child_info in browse_eligible_children[sid] %}
                                            <a class="item courses-register-trigger" data-target="register-child-{{ sid }}-{{ child_id }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ child_info.nickname ? child_info.nickname : child_info.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Hidden forms triggered by dropdown items (HTML5 form= attr would also work, but JS submission keeps Fomantic dropdown semantics) #}
                                {% if browse_can_self_register[sid] %}
                                    <form id="register-self-{{ sid }}" action="{{ url_for("coursesDoRegister", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endif %}
                                {% for child_id, child_info in browse_eligible_children[sid] %}
                                    <form id="register-child-{{ sid }}-{{ child_id }}" action="{{ url_for("coursesDoParentRegister", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        <input type="hidden" name="member_id" value="{{ child_id }}"/>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endfor %}
                            {% endif %}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                                {{ _T("Details", "courses") }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}{# end if not already #}
        {% endfor %}
        </div>
    {% endif %}
</div>

{# =========================================================
   ONGLET 2 — Mes inscriptions
   ========================================================= #}
<div class="ui bottom attached tab segment" data-tab="mine" style="padding:1em 0; border:none; box-shadow:none;">

    {% if registrations|length == 0 %}
        <div class="ui placeholder segment">
            <div class="ui icon header">
                <i class="calendar outline icon" aria-hidden="true"></i>
                {{ _T("You have no registrations yet.", "courses") }}
            </div>
            <button class="ui small primary button" id="go-browse-btn">
                {{ _T("Find a session", "courses") }}
            </button>
        </div>
    {% else %}

        {# Export iCal #}
        <div class="ui basic right aligned segment" style="padding-top:0;">
            <a href="{{ url_for("coursesMyRegistrationsIcal") }}" class="ui mini labeled icon button" title="{{ _T("Export all as iCal", "courses") }}">
                <i class="calendar download icon" aria-hidden="true"></i>
                iCal
            </a>
        </div>

        {# Prochaine séance #}
        {% if next_group|length > 0 %}

            {# Votre prochaine séance — toutes les inscriptions à la date la plus proche #}
            <h3 class="ui header courses-section-mt-sm">
                <i class="star icon" aria-hidden="true"></i>
                {{ _T("Your next session", "courses") }}
            </h3>
            <div class="ui stackable three column grid courses-cards-grid">
                {% for reg in next_group %}
                    {% set s = sessions[reg.getSessionId()] %}
                    {% set ev = events[s.getEventId()] %}
                    {% set mid = reg.getMemberId() %}
                    {% set is_out_of_group = out_of_group_regs[reg.getId()] is defined %}
                    <div class="column">
                        <div class="ui fluid card courses-card courses-next-session{% if is_out_of_group %} courses-card-out-of-group{% endif %}">
                            <div class="content">
                                <div class="right floated meta">
                                    {% if is_out_of_group %}
                                        <span class="ui orange label" title="{{ _T("You no longer belong to the required group for this event.", "courses") }}">
                                            <i class="exclamation triangle icon" aria-hidden="true"></i>
                                            {{ _T("Out of group", "courses") }}
                                        </span>
                                    {% else %}
                                        <span class="ui green label">{{ reg.getStatusLabel() }}</span>
                                    {% endif %}
                                </div>
                                <a class="header" href="{{ url_for("coursesEventShow", {"id": ev.getId()}) }}">
                                    {{ ev.getName() }}
                                </a>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                    <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                {% if ev.getLocation() %}
                                    <div class="meta">
                                        <i class="map pin icon" aria-hidden="true"></i>
                                        {{ ev.getLocation() }}
                                    </div>
                                {% endif %}
                                {% if mine_instructor_names[s.getId()] is defined %}
                                    <div class="meta">
                                        <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                        {{ mine_instructor_names[s.getId()] }}
                                    </div>
                                {% endif %}
                                {% if reg_members[mid] is defined %}
                                    <div class="meta courses-member-meta">
                                        <i class="user icon" aria-hidden="true"></i>
                                        {{ reg_members[mid].name }}
                                        {% if reg_members[mid].nickname %}
                                            <span class="ui teal mini label">
                                                <i class="tag icon" aria-hidden="true"></i>
                                                {{ reg_members[mid].nickname }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="extra content">
                                <a href="{{ url_for("coursesSessionShow", {"id": s.getId()}) }}" class="ui small primary button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                                <a href="{{ url_for("coursesSessionIcal", {"id": s.getId()}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                    <i class="calendar download icon" aria-hidden="true"></i>
                                </a>
                                {% if mid == current_member_id %}
                                    <form action="{{ url_for("coursesDoUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% else %}
                                    <form action="{{ url_for("coursesDoParentUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="member_id" value="{{ mid }}">
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Autres séances à venir (dates ultérieures) #}
            {% if rest_group|length > 0 %}
                <h3 class="ui header courses-section-mt">
                    <i class="clock icon" aria-hidden="true"></i>
                    {{ _T("Upcoming", "courses") }}
                </h3>
                <div class="ui stackable three column grid courses-cards-grid">
                    {% for reg in rest_group %}
                        {% set s = sessions[reg.getSessionId()] %}
                        {% set ev = events[s.getEventId()] %}
                        {% set mid = reg.getMemberId() %}
                        {% set is_out_of_group = out_of_group_regs[reg.getId()] is defined %}
                        <div class="column">
                            <div class="ui fluid card courses-card{% if is_out_of_group %} courses-card-out-of-group{% endif %}">
                                <div class="content">
                                    <div class="right floated meta">
                                        {% if is_out_of_group %}
                                            <span class="ui orange label" title="{{ _T("You no longer belong to the required group for this event.", "courses") }}">
                                                <i class="exclamation triangle icon" aria-hidden="true"></i>
                                                {{ _T("Out of group", "courses") }}
                                            </span>
                                        {% else %}
                                            <span class="ui green label">{{ reg.getStatusLabel() }}</span>
                                        {% endif %}
                                    </div>
                                    <a class="header" href="{{ url_for("coursesEventShow", {"id": ev.getId()}) }}">
                                        {{ ev.getName() }}
                                    </a>
                                    <div class="meta">
                                        <i class="calendar icon" aria-hidden="true"></i>
                                        <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                        <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                        &nbsp;&middot;&nbsp;
                                        {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                    </div>
                                    {% if ev.getLocation() %}
                                        <div class="meta">
                                            <i class="map pin icon" aria-hidden="true"></i>
                                            {{ ev.getLocation() }}
                                        </div>
                                    {% endif %}
                                    {% if mine_instructor_names[s.getId()] is defined %}
                                        <div class="meta">
                                            <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                            {{ mine_instructor_names[s.getId()] }}
                                        </div>
                                    {% endif %}
                                    {% if reg_members[mid] is defined %}
                                        <div class="meta courses-member-meta">
                                            <i class="user icon" aria-hidden="true"></i>
                                            {{ reg_members[mid].name }}
                                            {% if reg_members[mid].nickname %}
                                                <span class="ui teal mini label">
                                                    <i class="tag icon" aria-hidden="true"></i>
                                                    {{ reg_members[mid].nickname }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="extra content">
                                    <a href="{{ url_for("coursesSessionShow", {"id": s.getId()}) }}" class="ui small primary button">
                                        <i class="eye icon" aria-hidden="true"></i>
                                        {{ _T("Details", "courses") }}
                                    </a>
                                    <a href="{{ url_for("coursesSessionIcal", {"id": s.getId()}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                        <i class="calendar download icon" aria-hidden="true"></i>
                                    </a>
                                    {% if mid == current_member_id %}
                                        <form action="{{ url_for("coursesDoUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                            <button type="submit" class="ui small red labeled icon button">
                                                <i class="times icon" aria-hidden="true"></i>
                                                {{ _T("Unregister", "courses") }}
                                            </button>
                                            {% include 'components/forms/csrf.html.twig' %}
                                        </form>
                                    {% else %}
                                        <form action="{{ url_for("coursesDoParentUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                            <input type="hidden" name="member_id" value="{{ mid }}">
                                            <button type="submit" class="ui small red labeled icon button">
                                                <i class="times icon" aria-hidden="true"></i>
                                                {{ _T("Unregister", "courses") }}
                                            </button>
                                            {% include 'components/forms/csrf.html.twig' %}
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        {% else %}
            <div class="ui info message">
                <i class="info circle icon" aria-hidden="true"></i>
                {{ _T("No upcoming session", "courses") }}
            </div>
        {% endif %}

        {# Séances annulées #}
        {% if upcoming_cancelled|length > 0 %}
            <div class="ui red segment courses-section-mt">
                <h3 class="ui red header">
                    <i class="ban icon" aria-hidden="true"></i>
                    {{ _T("Cancelled sessions", "courses") }}
                    <span class="ui red circular label">{{ upcoming_cancelled|length }}</span>
                </h3>
                <div class="ui stackable three column grid courses-cards-grid">
                    {% for reg in upcoming_cancelled %}
                        {% set s = sessions[reg.getSessionId()] %}
                        {% set ev = events[s.getEventId()] %}
                        {% set mid = reg.getMemberId() %}
                        <div class="column">
                            <div class="ui fluid card courses-card courses-card-cancelled">
                                <div class="content">
                                    <div class="right floated meta">
                                        <span class="ui red label">{{ _T("Cancelled", "courses") }}</span>
                                    </div>
                                    <div class="header">{{ ev.getName() }}</div>
                                    <div class="meta">
                                        <i class="calendar icon" aria-hidden="true"></i>
                                        <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                        <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                        &nbsp;&middot;&nbsp;
                                        {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                    </div>
                                    {% if ev.getLocation() %}
                                        <div class="meta">
                                            <i class="map pin icon" aria-hidden="true"></i>
                                            {{ ev.getLocation() }}
                                        </div>
                                    {% endif %}
                                    {% if mine_instructor_names[s.getId()] is defined %}
                                        <div class="meta">
                                            <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                            {{ mine_instructor_names[s.getId()] }}
                                        </div>
                                    {% endif %}
                                    {% if reg_members[mid] is defined %}
                                        <div class="meta courses-member-meta">
                                            <i class="user icon" aria-hidden="true"></i>
                                            {{ reg_members[mid].name }}
                                            {% if reg_members[mid].nickname %}
                                                <span class="ui teal mini label">
                                                    <i class="tag icon" aria-hidden="true"></i>
                                                    {{ reg_members[mid].nickname }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% if s.getCancellationReason() %}
                                        <div class="courses-cancel-detail">
                                            <strong>{{ _T("Reason:", "courses") }}</strong>
                                            {{ s.getCancellationReasonLabel() }}
                                        </div>
                                    {% endif %}
                                    {% if s.getCancellationComment() %}
                                        <div class="courses-cancel-detail">
                                            <i class="comment outline icon" aria-hidden="true"></i>
                                            {{ s.getCancellationComment() }}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="extra content">
                                    <a href="{{ url_for("coursesSessionShow", {"id": s.getId()}) }}" class="ui small primary button">
                                        <i class="eye icon" aria-hidden="true"></i>
                                        {{ _T("Details", "courses") }}
                                    </a>
                                    <a href="{{ url_for("coursesSessionIcal", {"id": s.getId()}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                        <i class="calendar download icon" aria-hidden="true"></i>
                                    </a>
                                    {% if mid == current_member_id %}
                                        <form action="{{ url_for("coursesDoUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                            <button type="submit" class="ui small red labeled icon button">
                                                <i class="times icon" aria-hidden="true"></i>
                                                {{ _T("Unregister", "courses") }}
                                            </button>
                                            {% include 'components/forms/csrf.html.twig' %}
                                        </form>
                                    {% else %}
                                        <form action="{{ url_for("coursesDoParentUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                            <input type="hidden" name="member_id" value="{{ mid }}">
                                            <button type="submit" class="ui small red labeled icon button">
                                                <i class="times icon" aria-hidden="true"></i>
                                                {{ _T("Unregister", "courses") }}
                                            </button>
                                            {% include 'components/forms/csrf.html.twig' %}
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# Séances passées (repliable) #}
        {% if past|length > 0 %}
            <div class="courses-past-toggle courses-section-mt">
                <i class="dropdown icon" aria-hidden="true"></i>
                {{ _T("Past sessions", "courses") }} ({{ past|length }})
            </div>
            <div class="courses-past-content">
                <div class="ui stackable three column grid courses-cards-grid">
                    {% for reg in past|reverse %}
                        {% set s = sessions[reg.getSessionId()] %}
                        {% set ev = events[s.getEventId()] %}
                        {% set mid = reg.getMemberId() %}
                        <div class="column">
                            <div class="ui fluid card courses-card courses-past{% if s.getStatus() == 'cancelled' %} courses-card-cancelled{% endif %}">
                                <div class="content">
                                    <div class="header">{{ ev.getName() }}</div>
                                    <div class="meta">
                                        <i class="calendar icon" aria-hidden="true"></i>
                                        {{ s.getFormattedDate() }}
                                        &nbsp;&middot;&nbsp;
                                        {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                    </div>
                                    {% if mine_instructor_names[s.getId()] is defined %}
                                        <div class="meta">
                                            <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                            {{ mine_instructor_names[s.getId()] }}
                                        </div>
                                    {% endif %}
                                    {% if reg_members[mid] is defined %}
                                        <div class="meta courses-member-meta">
                                            <i class="user icon" aria-hidden="true"></i>
                                            {{ reg_members[mid].name }}
                                            {% if reg_members[mid].nickname %}
                                                <span class="ui teal mini label">
                                                    <i class="tag icon" aria-hidden="true"></i>
                                                    {{ reg_members[mid].nickname }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="extra content">
                                    {% if s.getStatus() == 'cancelled' %}
                                        <span class="ui red tiny label">
                                            <i class="ban icon" aria-hidden="true"></i>
                                            {{ _T("Cancelled", "courses") }}
                                        </span>
                                    {% else %}
                                        <span class="ui label">{{ reg.getStatusLabel() }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
<script>
$(function() {
    // Browse filters (client-side, plain HTML <select>s).
    var $today = $('#browse_date_from').val();

    function applyBrowseFilters() {
        var fType = $('#browse_type_filter').val() || '';
        var fName = $('#browse_name_filter').val() || '';
        var fDate = $('#browse_date_from').val() || '';
        var visible = 0;

        $('#browse-cards-grid .courses-browse-card-col').each(function() {
            var $col = $(this);
            var cType = ($col.attr('data-type-id') || '').toString();
            var cName = ($col.attr('data-event-name') || '').toString();
            var cDate = $col.attr('data-date') || '';

            var show = true;
            if (fType && cType !== fType.toString())                                show = false;
            if (fName && cName.trim().toLowerCase() !== fName.trim().toLowerCase()) show = false;
            if (fDate && cDate < fDate)                                             show = false;

            // Inline `!important` is the only thing that beats Fomantic
            // UI's `.ui.grid > .column { display: ... !important }` rule
            // (more specific than any of our classes).
            if (show) {
                $col[0].style.removeProperty('display');
            } else {
                $col[0].style.setProperty('display', 'none', 'important');
            }
            if (show) visible++;
        });

        $('#browse-no-results').toggle(visible === 0 && $('#browse-cards-grid').length > 0);
        var $badge = $('#browse-count-badge');
        if ($badge.length) {
            $badge.text(visible);
            $badge.toggle(visible > 0);
        }
    }

    function cascadeNameOptions() {
        // When a Type is picked, disable Name options that don't match.
        var fType = ($('#browse_type_filter').val() || '').toString();
        var $name = $('#browse_name_filter');
        $name.find('option').each(function() {
            var $opt = $(this);
            if ($opt.val() === '') { return; }
            var optType = ($opt.attr('data-type-id') || '').toString();
            $opt.prop('disabled', !!(fType && optType !== fType));
        });
        // Reset name if its current option is no longer enabled
        var curName = $name.val();
        if (curName) {
            var curOpt = $name.find('option[value="' + curName.replace(/"/g, '\\"') + '"]')[0];
            if (curOpt && curOpt.disabled) {
                $name.val('');
            }
        }
    }

    // Plain native change events fire reliably on plain <select>s.
    $('#browse_type_filter').on('change', function() {
        cascadeNameOptions();
        applyBrowseFilters();
    });
    $('#browse_name_filter').on('change', applyBrowseFilters);
    $('#browse_date_from').on('change', applyBrowseFilters);

    // Explicit Filter button — guaranteed trigger regardless of how the
    // user navigated the controls (touchscreen quirks, accessibility tools).
    $('#browse_apply_filter').on('click', applyBrowseFilters);

    $('#browse_clear_filter').on('click', function() {
        $('#browse_type_filter').val('');
        $('#browse_name_filter').find('option').prop('disabled', false);
        $('#browse_name_filter').val('');
        $('#browse_date_from').val($today);
        applyBrowseFilters();
    });

    // Tabs
    $('#my-sessions-tabs .item').on('click', function() {
        var tab = $(this).data('tab');
        $('#my-sessions-tabs .item').removeClass('active');
        $(this).addClass('active');
        $('.ui.bottom.attached.tab').removeClass('active');
        $('.ui.bottom.attached.tab[data-tab="' + tab + '"]').addClass('active');
        localStorage.setItem('my_sessions_tab', tab);
        if (tab === 'browse') {
            applyBrowseFilters();
            $('.ui.progress:visible').progress();
        }
    });

    // Restore tab from localStorage
    var savedTab = localStorage.getItem('my_sessions_tab') || 'browse';
    if (savedTab !== 'browse') {
        $('#my-sessions-tabs .item[data-tab="' + savedTab + '"]').trigger('click');
    } else {
        applyBrowseFilters();
        $('.ui.progress:visible').progress();
    }

    // "Trouver une séance" button from empty state
    $('#go-browse-btn').on('click', function() {
        $('#my-sessions-tabs .item[data-tab="browse"]').trigger('click');
    });

    // Séances passées repliables
    $('.courses-past-content').hide();
    $('.courses-past-toggle').on('click', function() {
        $(this).next('.courses-past-content').slideToggle(200);
        $(this).find('.dropdown.icon').toggleClass('rotated');
    });
});
</script>
{% endblock %}
