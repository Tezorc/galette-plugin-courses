{% extends "page.html.twig" %}

{% block content %}

{# =========================================================
   Préparer les données
   ========================================================= #}
{# Phase 65 : un seul flux chronologique pour les seances a venir (actives ET
   annulees). Le tri par date est deja garanti par Registrations::getForMembers
   (session_date ASC, start_time ASC). #}
{% set upcoming = [] %}
{% set past = [] %}
{% for reg in registrations %}
    {% set s = sessions[reg.getSessionId()] %}
    {% if s.getSessionDate() >= "now"|date("Y-m-d") %}
        {% set upcoming = upcoming|merge([reg]) %}
    {% else %}
        {% set past = past|merge([reg]) %}
    {% endif %}
{% endfor %}

{# Compter les séances disponibles : doit correspondre EXACTEMENT au
   filtre de la boucle de cartes ci-dessous (déjà inscrit OU plus aucune
   action possible -> carte non rendue, donc non comptée). #}
{% set browse_count = 0 %}
{% for s in available_sessions %}
    {% set _sid = s.getId() %}
    {% set _already = _sid in registered_session_ids %}
    {% set _no_action_left = not browse_can_self_register[_sid] and not browse_on_waitlist[_sid] and (browse_eligible_children[_sid] is not defined or browse_eligible_children[_sid]|length == 0) %}
    {% if not _already and not _no_action_left %}
        {% set browse_count = browse_count + 1 %}
    {% endif %}
{% endfor %}

{# =========================================================
   Phase 71.1 : Bandeau haut sticky = bannieres eligibilite + onglets,
   pour rester visible pendant le scroll comme un seul ensemble.
   ========================================================= #}
<div class="courses-sticky-top">
    {# Phase 47.2 : avertissement eligibilite (cotisation / actif / statut "Non membre") #}
    {% if ineligible_members|length > 0 %}
        <div class="ui orange message courses-sticky-message">
            <i class="exclamation triangle icon" aria-hidden="true"></i>
            <p>{{ _T("Registration will not be possible for the following member(s) until the situation is fixed:", "courses") }}</p>
            <ul>
                {% for reason in ineligible_members %}
                    <li>{{ reason }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {# Avertissement changement de groupe : inscriptions sur un evenement dont l'adherent ne fait plus partie du groupe requis #}
    {% if out_of_group_regs|length > 0 %}
        <div class="ui orange message courses-sticky-message">
            <i class="exclamation triangle icon" aria-hidden="true"></i>
            {{ _Tn("%d registration is on an event you no longer have access to (group membership changed). You can unregister from the marked card below.", "%d registrations are on events you no longer have access to (group membership changed). You can unregister from the marked cards below.", out_of_group_regs|length, "courses")|format(out_of_group_regs|length) }}
        </div>
    {% endif %}

    <div class="ui top attached tabular menu" id="my-sessions-tabs">
        <a class="item" data-tab="browse">
            <i class="search icon" aria-hidden="true"></i>
            <span class="courses-tab-text">{{ _T("Register for a next session", "courses") }}</span>
            <span id="browse-count-badge" class="ui teal circular label" style="margin-left:.4em;{% if browse_count == 0 %}display:none;{% endif %}">{{ browse_count }}</span>
        </a>
        <a class="item active" data-tab="mine">
            <i class="calendar check icon" aria-hidden="true"></i>
            <span class="courses-tab-text">{{ _T("My registrations", "courses") }}</span>
            {% set mine_badge = upcoming|length + my_waitlist_entries|length %}
            {% if mine_badge > 0 %}
                <span class="ui green circular label" style="margin-left:.4em">{{ mine_badge }}</span>
            {% endif %}
        </a>
    </div>
</div>

{# =========================================================
   ONGLET 1 — S'inscrire
   ========================================================= #}
<div class="ui bottom attached tab segment" data-tab="browse" style="padding:1em 0; border:none; box-shadow:none;">

    {# Phase 47.2: le bandeau d'eligibilite en tete du block content rend ce
       message redondant. Le flag member_is_up2date est conserve plus bas pour
       desactiver les boutons "S'inscrire" sur chaque carte. #}

    {% if available_sessions|length > 0 or browse_cancelled_sessions|length > 0 %}
    {# Filtres dynamiques (JS, sans rechargement)
       NOTE: les <select> sont volontairement des selects HTML natifs (pas
       de class="ui search dropdown") pour eviter les problemes de timing
       et de synchronisation de Fomantic UI. Les evenements `change`
       natifs sont fiables sur tous les navigateurs / mobiles. #}
    <div class="ui secondary yellow segment courses-browse-filters" style="margin-bottom:1em;">
        <div class="ui form">
            <div class="three fields" style="margin-bottom:.5em;">
                <div class="field">
                    <label for="browse_type_filter">{{ _T("Type", "courses") }}</label>
                    <select id="browse_type_filter" name="browse_type_filter" class="courses-native-select">
                        <option value="">{{ _T("All types", "courses") }}</option>
                        {% for type in browse_event_types %}
                            <option value="{{ type.getId() }}">{{ type.getLabel() }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="browse_name_filter">{{ _T("Activity", "courses") }}</label>
                    <select id="browse_name_filter" name="browse_name_filter" class="courses-native-select">
                        <option value="">{{ _T("All activities", "courses") }}</option>
                        {% for item in browse_available_names %}
                            <option value="{{ item.name }}" data-type-id="{{ item.type_id }}">{{ item.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="browse_date_from">{{ _T("From", "courses") }}</label>
                    <input type="date" id="browse_date_from" name="browse_date_from" value="{{ "now"|date("Y-m-d") }}"/>
                </div>
            </div>
            <div class="courses-filter-actions">
                <button type="button" id="browse_apply_filter" class="ui small labeled icon primary button">
                    <i class="search icon" aria-hidden="true"></i>
                    {{ _T("Filter", "courses") }}
                </button>
                <button type="button" id="browse_clear_filter" class="ui small labeled icon button">
                    <i class="trash alt red icon" aria-hidden="true"></i>
                    {{ _T("Clear filter", "courses") }}
                </button>
            </div>
        </div>
    </div>
    {% endif %}

    <div id="browse-no-results" class="ui info message" style="display:none;">
        <i class="search icon" aria-hidden="true"></i>
        {{ _T("No session matches your filters.", "courses") }}
    </div>

    {% if available_sessions|length == 0 and browse_cancelled_sessions|length == 0 %}
        <div class="ui info message">
            <i class="calendar outline icon" aria-hidden="true"></i>
            {{ _T("No upcoming session available.", "courses") }}
        </div>
    {% else %}
        {% if browse_all_sessions|length > 0 %}
        <div class="ui stackable three column grid courses-cards-grid" id="browse-cards-grid">
        {# Phase 65 : seances ouvertes ET annulees dans une seule grille triee par date #}
        {# Phase 70 : multi-plages groupees en UNE carte (non-primaires ignorees via browse_skip) #}
        {% for s in browse_all_sessions %}
            {% set sid = s.getId() %}
            {% set ev = browse_events[s.getEventId()] %}
            {% if browse_skip[sid] is defined %}
                {# Plage non-primaire d'un groupe multi-plages : deja rendue dans le dropdown de la carte primaire #}
            {% elseif browse_group_siblings[sid] is defined %}
            {# ====================== Carte multi-plages (Phase 70) ====================== #}
            {% set ms_slots = browse_group_siblings[sid] %}
            {% set ms_all_cancelled = true %}
            {% for ms_slot in ms_slots %}
                {% if ms_slot.getStatus() != 'cancelled' %}{% set ms_all_cancelled = false %}{% endif %}
            {% endfor %}
            <div class="column courses-browse-card-col"
                 {% if ms_all_cancelled %}data-cancelled="1"{% endif %}
                 data-type-id="{{ ev.getTypeId() }}"
                 data-event-name="{{ ev.getName() }}"
                 data-date="{{ s.getSessionDate() }}">
                <div class="ui fluid card courses-card">
                    <div class="content">
                        <div class="right floated meta">
                            <span class="ui small teal label">
                                <i class="clock icon" aria-hidden="true"></i>
                                {{ ms_slots|length }} {{ _T("Time slots", "courses") }}
                            </span>
                        </div>
                        <div class="header">{{ ev.getName() }}</div>
                        <div class="meta">
                            <i class="calendar icon" aria-hidden="true"></i>
                            <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                            <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                        </div>
                        {% if ev.getLocation() %}
                            <div class="meta">
                                <i class="map pin icon" aria-hidden="true"></i>
                                {{ ev.getLocation() }}
                            </div>
                        {% endif %}
                    </div>

                    {# Liste compacte des plages avec leur statut #}
                    <div class="content courses-multislot-list">
                        {% for ms_slot in ms_slots %}
                            {% set ms_sid = ms_slot.getId() %}
                            <div class="courses-multislot-row">
                                <strong>{{ ms_slot.getFormattedStartTime() }} - {{ ms_slot.getFormattedEndTime() }}</strong>
                                {% if ms_slot.getStatus() == 'cancelled' %}
                                    <span class="ui tiny red label">{{ _T("Cancelled", "courses") }}</span>
                                {% elseif browse_on_waitlist[ms_sid] %}
                                    <span class="ui tiny blue label">{{ _T("Waitlist", "courses") }}</span>
                                {% elseif ms_slot.isFull() %}
                                    <span class="ui tiny orange label">{{ _T("Full", "courses") }}</span>
                                {% else %}
                                    <span class="ui tiny green label">{{ _T("Open", "courses") }}</span>
                                {% endif %}
                                {% if ms_slot.getMaxCapacity() and ms_slot.getStatus() != 'cancelled' %}
                                    <small class="courses-multislot-cap">({{ ms_slot.getCurrentRegistrations() }}/{{ ms_slot.getMaxCapacity() }})</small>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>

                    {# Dropdown unique : (plage × membre) -> action register/waitlist #}
                    <div class="extra content">
                        <div class="courses-actions">
                            {# Phase 70.1 : la presence d'une plage dans le dropdown depend
                               desormais SOIT du parent (self_actionable), SOIT des enfants
                               eligibles, independamment. Cela permet d'inscrire un enfant sur
                               une plage ou le parent est deja inscrit ou en attente. #}
                            {% set ms_has_items = false %}
                            {% for ms_slot in ms_slots %}
                                {% set ms_sid = ms_slot.getId() %}
                                {% set ms_slot_open = ms_slot.getStatus() != 'cancelled' and (browse_has_instructor[ms_sid] or ev.isRegistrationAllowedWithoutInstructor()) %}
                                {% set ms_self_act = ms_slot_open and browse_can_self_register[ms_sid] and not browse_on_waitlist[ms_sid] and ms_sid not in registered_session_ids %}
                                {% set ms_kids_act = ms_slot_open and (browse_eligible_children[ms_sid] is defined and browse_eligible_children[ms_sid]|length > 0) %}
                                {% if ms_self_act or ms_kids_act %}{% set ms_has_items = true %}{% endif %}
                            {% endfor %}

                            {% if ms_has_items and member_is_up2date %}
                                <div class="ui simple dropdown tiny labeled icon green button">
                                    <i class="user plus icon" aria-hidden="true"></i>
                                    <span class="text">{{ _T("Register", "courses") }}</span>
                                    <i class="dropdown icon" aria-hidden="true"></i>
                                    <div class="menu">
                                        {% for ms_slot in ms_slots %}
                                            {% set ms_sid = ms_slot.getId() %}
                                            {% set ms_slot_open = ms_slot.getStatus() != 'cancelled' and (browse_has_instructor[ms_sid] or ev.isRegistrationAllowedWithoutInstructor()) %}
                                            {% set ms_self_act = ms_slot_open and browse_can_self_register[ms_sid] and not browse_on_waitlist[ms_sid] and ms_sid not in registered_session_ids %}
                                            {% set ms_children = ms_slot_open and browse_eligible_children[ms_sid] is defined ? browse_eligible_children[ms_sid] : {} %}
                                            {% if ms_self_act or ms_children|length > 0 %}
                                                <div class="header courses-multislot-menu-header">
                                                    <i class="clock icon" aria-hidden="true"></i>
                                                    {{ ms_slot.getFormattedStartTime() }} - {{ ms_slot.getFormattedEndTime() }}
                                                    {% if ms_slot.isFull() %}
                                                        <span class="ui mini orange label">{{ _T("Waitlist", "courses") }}</span>
                                                    {% endif %}
                                                </div>
                                                {% if ms_self_act %}
                                                    {% set ms_self_nick = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                                    <a class="item courses-register-trigger" data-target="ms-self-{{ ms_sid }}">
                                                        <i class="user icon" aria-hidden="true"></i>
                                                        {{ ms_self_nick ?: _T("Myself", "courses") }}
                                                    </a>
                                                {% endif %}
                                                {% for child_id, child_info in ms_children %}
                                                    <a class="item courses-register-trigger" data-target="ms-child-{{ ms_sid }}-{{ child_id }}">
                                                        <i class="user icon" aria-hidden="true"></i>
                                                        {{ child_info.nickname ?: child_info.name }}
                                                    </a>
                                                {% endfor %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Hidden forms : 1 par (slot, membre, action). Memes gardes que le menu. #}
                                {% for ms_slot in ms_slots %}
                                    {% set ms_sid = ms_slot.getId() %}
                                    {% set ms_slot_open = ms_slot.getStatus() != 'cancelled' and (browse_has_instructor[ms_sid] or ev.isRegistrationAllowedWithoutInstructor()) %}
                                    {% if ms_slot_open %}
                                        {% set ms_self_url = ms_slot.isFull() ? url_for("coursesDoWaitlist", {"id": ms_sid}) : url_for("coursesDoRegister", {"id": ms_sid}) %}
                                        {% set ms_child_url = ms_slot.isFull() ? url_for("coursesDoParentWaitlist", {"id": ms_sid}) : url_for("coursesDoParentRegister", {"id": ms_sid}) %}
                                        {% set ms_self_act = browse_can_self_register[ms_sid] and not browse_on_waitlist[ms_sid] and ms_sid not in registered_session_ids %}
                                        {% if ms_self_act %}
                                            <form id="ms-self-{{ ms_sid }}" action="{{ ms_self_url }}" method="post" class="courses-hidden-form">
                                                <input type="hidden" name="redirect_to" value="my_registrations"/>
                                                {% include "components/forms/csrf.html.twig" %}
                                            </form>
                                        {% endif %}
                                        {% if browse_eligible_children[ms_sid] is defined %}
                                            {% for child_id, child_info in browse_eligible_children[ms_sid] %}
                                                <form id="ms-child-{{ ms_sid }}-{{ child_id }}" action="{{ ms_child_url }}" method="post" class="courses-hidden-form">
                                                    <input type="hidden" name="redirect_to" value="my_registrations"/>
                                                    <input type="hidden" name="member_id" value="{{ child_id }}"/>
                                                    {% include "components/forms/csrf.html.twig" %}
                                                </form>
                                            {% endfor %}
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                                {{ _T("Details", "courses") }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% elseif s.getStatus() == 'cancelled' %}
            {# ---- Carte annulee (informatif, melangee chronologiquement) ---- #}
            <div class="column courses-browse-card-col"
                 data-cancelled="1"
                 data-type-id="{{ ev.getTypeId() }}"
                 data-event-name="{{ ev.getName() }}"
                 data-date="{{ s.getSessionDate() }}">
                <div class="ui fluid card courses-card courses-card-cancelled">
                    <div class="content">
                        <div class="right floated meta">
                            <span class="ui red label">{{ _T("Cancelled", "courses") }}</span>
                        </div>
                        <div class="header">{{ ev.getName() }}</div>
                        <div class="meta">
                            <i class="calendar icon" aria-hidden="true"></i>
                            <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                            <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                            &nbsp;&middot;&nbsp;
                            {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                        </div>
                        {% if ev.getLocation() %}
                            <div class="meta">
                                <i class="map pin icon" aria-hidden="true"></i>
                                {{ ev.getLocation() }}
                            </div>
                        {% endif %}
                        {% if s.getCancellationReason() %}
                            <div class="courses-cancel-detail">
                                <strong>{{ _T("Reason:", "courses") }}</strong>
                                {{ s.getCancellationReasonLabel() }}
                            </div>
                        {% endif %}
                        {% if s.getCancellationComment() %}
                            <div class="courses-cancel-detail">
                                <i class="comment outline icon" aria-hidden="true"></i>
                                {{ s.getCancellationComment() }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="extra content">
                        <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                            <i class="eye icon" aria-hidden="true"></i>
                            {{ _T("Details", "courses") }}
                        </a>
                    </div>
                </div>
            </div>
            {% else %}
            {% set already = sid in registered_session_ids %}
            {% set on_wl = browse_on_waitlist[sid] %}
            {% set has_instr = browse_has_instructor[sid] %}

            {% set no_action_left = not browse_can_self_register[sid] and not browse_on_waitlist[sid] and (browse_eligible_children[sid] is not defined or browse_eligible_children[sid]|length == 0) %}
            {# Phase 68 : ne pas masquer la carte si les enfants peuvent encore agir (inscription ou liste d'attente) #}
            {% set children_have_action = browse_eligible_children[sid] is defined and browse_eligible_children[sid]|length > 0 %}
            {% if not no_action_left and (not already or children_have_action) %}
            <div class="column courses-browse-card-col"
                 data-type-id="{{ ev.getTypeId() }}"
                 data-event-name="{{ ev.getName() }}"
                 data-date="{{ s.getSessionDate() }}">
                <div class="ui fluid card courses-card">
                    <div class="content">
                        {# Badge statut #}
                        <div class="right floated meta">
                            {% if on_wl %}
                                <span class="ui blue label">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Waitlist", "courses") }}
                                </span>
                            {% elseif not has_instr and not ev.isRegistrationAllowedWithoutInstructor() %}
                                <span class="ui orange label">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Awaiting instructor", "courses") }}
                                </span>
                            {% elseif s.isFull() %}
                                <span class="ui orange label">{{ _T("Full", "courses") }}</span>
                            {% else %}
                                <span class="ui green label">{{ _T("Open", "courses") }}</span>
                            {% endif %}
                            {% if browse_conflicts[sid] is defined %}
                                <span class="ui orange basic label" title="{{ _T("Schedule conflict with:", "courses") }} {{ browse_conflicts[sid]|join(' ; ') }}">
                                    <i class="exclamation triangle icon" aria-hidden="true"></i>
                                    {{ _T("Schedule conflict", "courses") }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="header">{{ ev.getName() }}</div>

                        <div class="meta">
                            <i class="calendar icon" aria-hidden="true"></i>
                            <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                            <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                            &nbsp;&middot;&nbsp;
                            {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                        </div>
                        {% if ev.getLocation() %}
                            <div class="meta">
                                <i class="map pin icon" aria-hidden="true"></i>
                                {{ ev.getLocation() }}
                            </div>
                        {% endif %}
                        {% if has_instr and browse_instructor_names[sid] is defined %}
                            <div class="meta">
                                <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                {{ browse_instructor_names[sid] }}
                            </div>
                        {% endif %}
                    </div>

                    {# Jauge capacité #}
                    {% if s.getMaxCapacity() %}
                        <div class="content">
                            <div class="ui tiny progress{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                            </div>
                        </div>
                    {% endif %}

                    {# Actions #}
                    <div class="extra content">
                        {% if on_wl %}
                            {# Parent sur liste d'attente. Phase 68 : on permet aussi aux enfants d'agir #}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny button">
                                <i class="eye icon" aria-hidden="true"></i>
                                {{ _T("Details", "courses") }}
                            </a>
                            {% if children_have_action and (has_instr or ev.isRegistrationAllowedWithoutInstructor()) and member_is_up2date %}
                                {% set onwl_action_url = s.isFull() ? url_for("coursesDoParentWaitlist", {"id": sid}) : url_for("coursesDoParentRegister", {"id": sid}) %}
                                {% set onwl_btn_class = s.isFull() ? 'ui tiny labeled icon blue button' : 'ui tiny labeled icon teal button' %}
                                {% set onwl_icon      = s.isFull() ? 'clock' : 'user plus' %}
                                {% set onwl_label     = s.isFull() ? _T("Join waitlist", "courses") : _T("Register", "courses") %}
                                {% set onwl_prefix    = s.isFull() ? 'wl-onwl-child' : 'reg-onwl-child' %}
                                {% if browse_eligible_children[sid]|length == 1 %}
                                    {% set onwl_only_child_id = browse_eligible_children[sid]|keys|first %}
                                    {% set onwl_only_child = browse_eligible_children[sid][onwl_only_child_id] %}
                                    <form action="{{ onwl_action_url }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ onwl_only_child_id }}"/>
                                        <button type="submit" class="{{ onwl_btn_class }}">
                                            <i class="{{ onwl_icon }} icon" aria-hidden="true"></i>
                                            {{ onwl_only_child.nickname ? onwl_only_child.nickname : onwl_only_child.name }}
                                        </button>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% else %}
                                    <div class="ui simple dropdown {{ onwl_btn_class }}">
                                        <i class="{{ onwl_icon }} icon" aria-hidden="true"></i>
                                        <span class="text">{{ onwl_label }}</span>
                                        <i class="dropdown icon" aria-hidden="true"></i>
                                        <div class="menu">
                                            {% for child_id, child_info in browse_eligible_children[sid] %}
                                                <a class="item courses-register-trigger" data-target="{{ onwl_prefix }}-{{ sid }}-{{ child_id }}">
                                                    <i class="user icon" aria-hidden="true"></i>
                                                    {{ child_info.nickname ? child_info.nickname : child_info.name }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    {% for child_id, child_info in browse_eligible_children[sid] %}
                                        <form id="{{ onwl_prefix }}-{{ sid }}-{{ child_id }}" action="{{ onwl_action_url }}" method="post" class="courses-hidden-form">
                                            <input type="hidden" name="redirect_to" value="my_registrations"/>
                                            <input type="hidden" name="member_id" value="{{ child_id }}"/>
                                            {% include "components/forms/csrf.html.twig" %}
                                        </form>
                                    {% endfor %}
                                {% endif %}
                            {% endif %}
                        {% elseif not has_instr and not ev.isRegistrationAllowedWithoutInstructor() %}
                            {# Pas d'instructeur et inscription bloquee par defaut — pas d'inscription possible #}
                            <span class="ui tiny orange label">
                                <i class="exclamation triangle icon" aria-hidden="true"></i>
                                {{ _T("No instructor", "courses") }}
                            </span>
                        {% elseif not member_is_up2date %}
                            {# Cotisation non à jour #}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny button">
                                {{ _T("Details", "courses") }}
                            </a>
                        {% elseif s.isFull() %}
                            {# Session complète : liste d'attente (membre lui-même + enfants éligibles), même UX que l'inscription #}
                            {# Phase 68 : si le parent est deja inscrit (`already`), il n'apparait pas dans le dropdown waitlist #}
                            {% set wl_self_count = (browse_can_self_register[sid] and not already) ? 1 : 0 %}
                            {% set wl_children_count = (browse_eligible_children[sid] is defined) ? browse_eligible_children[sid]|length : 0 %}
                            {% set wl_total_options = wl_self_count + wl_children_count %}

                            {% if wl_total_options == 1 and browse_can_self_register[sid] %}
                                {# Seule option : le membre lui-même #}
                                <form action="{{ url_for("coursesDoWaitlist", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <input type="hidden" name="redirect_to" value="my_registrations"/>
                                    <button type="submit" class="ui tiny labeled icon blue button">
                                        <i class="clock icon" aria-hidden="true"></i>
                                        {{ _T("Join waitlist", "courses") }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif wl_total_options == 1 %}
                                {# Seule option : un seul enfant — POST direct, bouton porte son nom #}
                                {% set only_wl_child_id = browse_eligible_children[sid]|keys|first %}
                                {% set only_wl_child_info = browse_eligible_children[sid][only_wl_child_id] %}
                                <form action="{{ url_for("coursesDoParentWaitlist", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <input type="hidden" name="redirect_to" value="my_registrations"/>
                                    <input type="hidden" name="member_id" value="{{ only_wl_child_id }}"/>
                                    <button type="submit" class="ui tiny labeled icon blue button">
                                        <i class="clock icon" aria-hidden="true"></i>
                                        {{ only_wl_child_info.nickname ? only_wl_child_info.nickname : only_wl_child_info.name }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif wl_total_options >= 2 %}
                                {# Plusieurs options : un seul bouton dropdown qui liste les choix #}
                                <div class="ui simple dropdown tiny labeled icon blue button">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    <span class="text">{{ _T("Join waitlist", "courses") }}</span>
                                    <i class="dropdown icon" aria-hidden="true"></i>
                                    <div class="menu">
                                        {% if wl_self_count == 1 %}
                                            {% set self_nick_wl = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                            <a class="item courses-register-trigger" data-target="waitlist-self-{{ sid }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ self_nick_wl ? self_nick_wl : _T("Myself", "courses") }}
                                            </a>
                                        {% endif %}
                                        {% for child_id, child_info in browse_eligible_children[sid] %}
                                            <a class="item courses-register-trigger" data-target="waitlist-child-{{ sid }}-{{ child_id }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ child_info.nickname ? child_info.nickname : child_info.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Hidden forms triggered by dropdown items #}
                                {% if wl_self_count == 1 %}
                                    <form id="waitlist-self-{{ sid }}" action="{{ url_for("coursesDoWaitlist", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endif %}
                                {% for child_id, child_info in browse_eligible_children[sid] %}
                                    <form id="waitlist-child-{{ sid }}-{{ child_id }}" action="{{ url_for("coursesDoParentWaitlist", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ child_id }}"/>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endfor %}
                            {% endif %}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                                {{ _T("Details", "courses") }}
                            </a>
                        {% else %}
                            {# Phase 68 : si le parent est deja inscrit (`already`), il n'apparait pas dans le dropdown register #}
                            {% set self_count = (browse_can_self_register[sid] and not already) ? 1 : 0 %}
                            {% set children_count = (browse_eligible_children[sid] is defined) ? browse_eligible_children[sid]|length : 0 %}
                            {% set total_options = self_count + children_count %}

                            {% if total_options == 1 and self_count == 1 %}
                                {# Seule option : le membre lui-meme — on affiche le nickname si dispo #}
                                {% set self_nick = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                <form action="{{ url_for("coursesDoRegister", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <input type="hidden" name="redirect_to" value="my_registrations"/>
                                    <button type="submit" class="ui tiny labeled icon green button">
                                        <i class="user plus icon" aria-hidden="true"></i>
                                        {{ self_nick ? self_nick : _T("Register", "courses") }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif total_options == 1 %}
                                {# Seule option : un seul enfant — POST direct, bouton porte son nom #}
                                {% set only_child_id = browse_eligible_children[sid]|keys|first %}
                                {% set only_child_info = browse_eligible_children[sid][only_child_id] %}
                                <form action="{{ url_for("coursesDoParentRegister", {"id": sid}) }}" method="post" class="ui form courses-inline-form">
                                    <input type="hidden" name="redirect_to" value="my_registrations"/>
                                    <input type="hidden" name="member_id" value="{{ only_child_id }}"/>
                                    <button type="submit" class="ui tiny labeled icon teal button">
                                        <i class="user plus icon" aria-hidden="true"></i>
                                        {{ only_child_info.nickname ? only_child_info.nickname : only_child_info.name }}
                                    </button>
                                    {% include "components/forms/csrf.html.twig" %}
                                </form>
                            {% elseif total_options >= 2 %}
                                {# Plusieurs options : un seul bouton dropdown qui liste les choix #}
                                <div class="ui simple dropdown tiny labeled icon teal button">
                                    <i class="user plus icon" aria-hidden="true"></i>
                                    <span class="text">{{ _T("Register", "courses") }}</span>
                                    <i class="dropdown icon" aria-hidden="true"></i>
                                    <div class="menu">
                                        {% if self_count == 1 %}
                                            {% set self_nick_drop = (reg_members[login.id] is defined and reg_members[login.id].nickname) ? reg_members[login.id].nickname : '' %}
                                            <a class="item courses-register-trigger" data-target="register-self-{{ sid }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ self_nick_drop ? self_nick_drop : _T("Myself", "courses") }}
                                            </a>
                                        {% endif %}
                                        {% for child_id, child_info in browse_eligible_children[sid] %}
                                            <a class="item courses-register-trigger" data-target="register-child-{{ sid }}-{{ child_id }}">
                                                <i class="user icon" aria-hidden="true"></i>
                                                {{ child_info.nickname ? child_info.nickname : child_info.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Hidden forms triggered by dropdown items (HTML5 form= attr would also work, but JS submission keeps Fomantic dropdown semantics) #}
                                {% if self_count == 1 %}
                                    <form id="register-self-{{ sid }}" action="{{ url_for("coursesDoRegister", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endif %}
                                {% for child_id, child_info in browse_eligible_children[sid] %}
                                    <form id="register-child-{{ sid }}-{{ child_id }}" action="{{ url_for("coursesDoParentRegister", {"id": sid}) }}" method="post" class="courses-hidden-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ child_id }}"/>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endfor %}
                            {% endif %}
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui tiny basic button">
                                {{ _T("Details", "courses") }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}{# end if not already #}
            {% endif %}{# end if cancelled / else #}
        {% endfor %}
        </div>
        {% endif %}{# end if browse_all_sessions > 0 #}
    {% endif %}
</div>

{# =========================================================
   ONGLET 2 — Mes inscriptions
   ========================================================= #}
<div class="ui bottom attached tab segment active" data-tab="mine" style="padding:1em 0; border:none; box-shadow:none;">

    {% if registrations|length == 0 %}
        <div class="ui placeholder segment">
            <div class="ui icon header">
                <i class="calendar outline icon" aria-hidden="true"></i>
                {{ _T("You have no registrations yet.", "courses") }}
            </div>
            <button class="ui small primary button" id="go-browse-btn">
                {{ _T("Register for a next session", "courses") }}
            </button>
        </div>
    {% else %}

        {# Export iCal #}
        <div class="ui basic right aligned segment" style="padding-top:0;">
            <a href="{{ url_for("coursesMyRegistrationsIcal") }}" class="ui mini labeled icon button" title="{{ _T("Export all as iCal", "courses") }}">
                <i class="calendar download icon" aria-hidden="true"></i>
                iCal
            </a>
        </div>

        {# Phase 65 : flux unique des seances a venir (actives + annulees), par date #}
        {% if upcoming|length > 0 %}
            <h3 class="ui header courses-section-mt-sm">
                <i class="clock icon" aria-hidden="true"></i>
                {{ _T("Upcoming", "courses") }}
            </h3>
            <div class="ui stackable three column grid courses-cards-grid">
                {% for reg in upcoming %}
                    {% set s = sessions[reg.getSessionId()] %}
                    {% set ev = events[s.getEventId()] %}
                    {% set mid = reg.getMemberId() %}
                    {% if s.getStatus() == 'cancelled' %}
                    {# ---- Carte seance annulee (informatif + desinscription) ---- #}
                    <div class="column">
                        <div class="ui fluid card courses-card courses-card-cancelled">
                            <div class="content">
                                <div class="right floated meta">
                                    <span class="ui red label">{{ _T("Cancelled", "courses") }}</span>
                                </div>
                                <div class="header">{{ ev.getName() }}</div>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                    <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                {% if ev.getLocation() %}
                                    <div class="meta">
                                        <i class="map pin icon" aria-hidden="true"></i>
                                        {{ ev.getLocation() }}
                                    </div>
                                {% endif %}
                                {% if mine_instructor_names[s.getId()] is defined %}
                                    <div class="meta">
                                        <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                        {{ mine_instructor_names[s.getId()] }}
                                    </div>
                                {% endif %}
                                {% if reg_members[mid] is defined %}
                                    <div class="meta courses-member-meta">
                                        <i class="user icon" aria-hidden="true"></i>
                                        {{ reg_members[mid].name }}
                                        {% if reg_members[mid].nickname %}
                                            <span class="ui teal mini label">
                                                <i class="tag icon" aria-hidden="true"></i>
                                                {{ reg_members[mid].nickname }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                                {% if s.getCancellationReason() %}
                                    <div class="courses-cancel-detail">
                                        <strong>{{ _T("Reason:", "courses") }}</strong>
                                        {{ s.getCancellationReasonLabel() }}
                                    </div>
                                {% endif %}
                                {% if s.getCancellationComment() %}
                                    <div class="courses-cancel-detail">
                                        <i class="comment outline icon" aria-hidden="true"></i>
                                        {{ s.getCancellationComment() }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="extra content">
                                <a href="{{ url_for("coursesSessionShow", {"id": s.getId()}) }}" class="ui small primary button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                                <a href="{{ url_for("coursesSessionIcal", {"id": s.getId()}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                    <i class="calendar download icon" aria-hidden="true"></i>
                                </a>
                                {% if mid == current_member_id %}
                                    <form action="{{ url_for("coursesDoUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% else %}
                                    <form action="{{ url_for("coursesDoParentUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ mid }}">
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% else %}
                    {% set is_out_of_group = out_of_group_regs[reg.getId()] is defined %}
                    <div class="column">
                        <div class="ui fluid card courses-card{% if is_out_of_group %} courses-card-out-of-group{% endif %}">
                            <div class="content">
                                <div class="right floated meta">
                                    {% if is_out_of_group %}
                                        <span class="ui orange label" title="{{ _T("You no longer belong to the required group for this event.", "courses") }}">
                                            <i class="exclamation triangle icon" aria-hidden="true"></i>
                                            {{ _T("Out of group", "courses") }}
                                        </span>
                                    {% else %}
                                        <span class="ui green label">{{ reg.getStatusLabel() }}</span>
                                    {% endif %}
                                    {% if my_conflicts[reg.getId()] is defined %}
                                        <span class="ui orange basic label" title="{{ _T("Schedule conflict with:", "courses") }} {{ my_conflicts[reg.getId()]|join(' ; ') }}">
                                            <i class="exclamation triangle icon" aria-hidden="true"></i>
                                            {{ _T("Schedule conflict", "courses") }}
                                        </span>
                                    {% endif %}
                                </div>
                                <a class="header" href="{{ url_for("coursesEventShow", {"id": ev.getId()}) }}">
                                    {{ ev.getName() }}
                                </a>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                    <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                {% if ev.getLocation() %}
                                    <div class="meta">
                                        <i class="map pin icon" aria-hidden="true"></i>
                                        {{ ev.getLocation() }}
                                    </div>
                                {% endif %}
                                {% if mine_instructor_names[s.getId()] is defined %}
                                    <div class="meta">
                                        <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                        {{ mine_instructor_names[s.getId()] }}
                                    </div>
                                {% endif %}
                                {% if reg_members[mid] is defined %}
                                    <div class="meta courses-member-meta">
                                        <i class="user icon" aria-hidden="true"></i>
                                        {{ reg_members[mid].name }}
                                        {% if reg_members[mid].nickname %}
                                            <span class="ui teal mini label">
                                                <i class="tag icon" aria-hidden="true"></i>
                                                {{ reg_members[mid].nickname }}
                                            </span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            {# Jauge capacité #}
                            {% if s.getMaxCapacity() %}
                                <div class="content">
                                    <div class="ui tiny progress{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                        <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                        <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="content">
                                    <i class="users icon" aria-hidden="true"></i>
                                    {{ s.getCurrentRegistrations() }} {{ _T("registered", "courses") }}
                                </div>
                            {% endif %}
                            <div class="extra content">
                                <a href="{{ url_for("coursesSessionShow", {"id": s.getId()}) }}" class="ui small primary button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                                <a href="{{ url_for("coursesSessionIcal", {"id": s.getId()}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                    <i class="calendar download icon" aria-hidden="true"></i>
                                </a>
                                {% if mid == current_member_id %}
                                    <form action="{{ url_for("coursesDoUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% else %}
                                    <form action="{{ url_for("coursesDoParentUnregister", {"id": s.getId()}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ mid }}">
                                        <button type="submit" class="ui small red labeled icon button">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Unregister", "courses") }}
                                        </button>
                                        {% include 'components/forms/csrf.html.twig' %}
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endif %}{# fin branche annulee / active #}
                {% endfor %}
            </div>

        {% else %}
            <div class="ui info message">
                <i class="info circle icon" aria-hidden="true"></i>
                {{ _T("No upcoming session", "courses") }}
            </div>
        {% endif %}

        {# Phase 67: Séances où l'on est sur liste d'attente (parent + enfants), bloc dédié chronologique #}
        {% if my_waitlist_entries|length > 0 %}
            <h3 class="ui small dividing header courses-section-mt">
                <i class="clock icon" aria-hidden="true"></i>
                <div class="content">
                    {{ _T("On the waitlist", "courses") }}
                    <span class="ui blue circular label">{{ my_waitlist_entries|length }}</span>
                </div>
            </h3>
            <div class="ui stackable three column grid courses-cards-grid">
            {% for wl in my_waitlist_entries %}
                {% set wsid = wl.getSessionId() %}
                {% set ws   = sessions[wsid] %}
                {% set wev  = events[ws.getEventId()] %}
                {% set wmid = wl.getMemberId() %}
                {% set is_self_wl = (wmid == current_member_id) %}
                {% set wmname = (reg_members[wmid] is defined and reg_members[wmid].nickname) ? reg_members[wmid].nickname : ((reg_members[wmid] is defined) ? reg_members[wmid].name : '') %}
                <div class="column">
                    <div class="ui fluid card courses-card">
                        <div class="content">
                            <div class="right floated meta">
                                <span class="ui blue label">
                                    <i class="clock icon" aria-hidden="true"></i>
                                    {{ _T("Waitlist", "courses") }} #{{ wl.getPosition() }}
                                </span>
                            </div>
                            <div class="header">{{ wev.getName() }}</div>
                            <div class="meta">
                                <i class="calendar icon" aria-hidden="true"></i>
                                <span class="courses-date-day">{{ ws.getSessionDate()|date("d") }}</span>
                                <span class="courses-date-month">{{ ws.getMonthYear() }}</span>
                                &nbsp;&middot;&nbsp;
                                {{ ws.getFormattedStartTime() }} - {{ ws.getFormattedEndTime() }}
                            </div>
                            {% if wev.getLocation() %}
                                <div class="meta">
                                    <i class="map pin icon" aria-hidden="true"></i>
                                    {{ wev.getLocation() }}
                                </div>
                            {% endif %}
                            {% if not is_self_wl and wmname %}
                                <div class="meta">
                                    <i class="user icon" aria-hidden="true"></i>
                                    {{ wmname }}
                                </div>
                            {% endif %}
                        </div>
                        <div class="extra content">
                            <div class="courses-actions">
                                <a href="{{ url_for("coursesSessionShow", {"id": wsid}) }}" class="ui tiny button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                                {% if is_self_wl %}
                                    <form action="{{ url_for("coursesDoLeaveWaitlist", {"id": wsid}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <button type="submit" class="ui tiny labeled icon orange button fluid">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Leave waitlist", "courses") }}
                                        </button>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% else %}
                                    <form action="{{ url_for("coursesDoParentLeaveWaitlist", {"id": wsid}) }}" method="post" class="ui form courses-inline-form">
                                        <input type="hidden" name="redirect_to" value="my_registrations"/>
                                        <input type="hidden" name="member_id" value="{{ wmid }}"/>
                                        <button type="submit" class="ui tiny labeled icon orange button fluid">
                                            <i class="times icon" aria-hidden="true"></i>
                                            {{ _T("Leave waitlist", "courses") }}
                                        </button>
                                        {% include "components/forms/csrf.html.twig" %}
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
            </div>
        {% endif %}

        {# Séances passées (repliable) #}
        {% if past|length > 0 %}
            <div class="courses-past-toggle courses-section-mt">
                <i class="dropdown icon" aria-hidden="true"></i>
                {{ _T("Past sessions", "courses") }} ({{ past|length }})
            </div>
            <div class="courses-past-content">
                <div class="ui stackable three column grid courses-cards-grid">
                    {% for reg in past|reverse %}
                        {% set s = sessions[reg.getSessionId()] %}
                        {% set ev = events[s.getEventId()] %}
                        {% set mid = reg.getMemberId() %}
                        <div class="column">
                            <div class="ui fluid card courses-card courses-past{% if s.getStatus() == 'cancelled' %} courses-card-cancelled{% endif %}">
                                <div class="content">
                                    <div class="header">{{ ev.getName() }}</div>
                                    <div class="meta">
                                        <i class="calendar icon" aria-hidden="true"></i>
                                        {{ s.getFormattedDate() }}
                                        &nbsp;&middot;&nbsp;
                                        {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                    </div>
                                    {% if mine_instructor_names[s.getId()] is defined %}
                                        <div class="meta">
                                            <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                            {{ mine_instructor_names[s.getId()] }}
                                        </div>
                                    {% endif %}
                                    {% if reg_members[mid] is defined %}
                                        <div class="meta courses-member-meta">
                                            <i class="user icon" aria-hidden="true"></i>
                                            {{ reg_members[mid].name }}
                                            {% if reg_members[mid].nickname %}
                                                <span class="ui teal mini label">
                                                    <i class="tag icon" aria-hidden="true"></i>
                                                    {{ reg_members[mid].nickname }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                {# Jauge capacité #}
                                {% if s.getMaxCapacity() %}
                                    <div class="content">
                                        <div class="ui tiny progress{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                            <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                            <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="content">
                                        <i class="users icon" aria-hidden="true"></i>
                                        {{ s.getCurrentRegistrations() }} {{ _T("registered", "courses") }}
                                    </div>
                                {% endif %}
                                <div class="extra content">
                                    {% if s.getStatus() == 'cancelled' %}
                                        <span class="ui red tiny label">
                                            <i class="ban icon" aria-hidden="true"></i>
                                            {{ _T("Cancelled", "courses") }}
                                        </span>
                                    {% else %}
                                        <span class="ui label">{{ reg.getStatusLabel() }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
<script>
$(function() {
    // Browse filters (client-side, plain HTML <select>s).
    var $today = $('#browse_date_from').val();
    // Phase 74.1: cache cards/badges outside the filter function — querying
    // the DOM on every keystroke is wasteful, and counting visible
    // non-cancelled cards via a second selector + .filter() forces an
    // extra layout pass. We track both metrics inline in the main loop.
    var browseGridNodes  = document.querySelectorAll('#browse-cards-grid .courses-browse-card-col');
    var $browseNoResults = $('#browse-no-results');
    var $browseBadge     = $('#browse-count-badge');
    var browseHasGrid    = document.getElementById('browse-cards-grid') !== null;

    function applyBrowseFilters() {
        var fType = ($('#browse_type_filter').val() || '').toString();
        var fName = ($('#browse_name_filter').val() || '').trim().toLowerCase();
        var fDate = $('#browse_date_from').val() || '';

        var visible = 0;
        var actionable = 0;
        for (var i = 0, len = browseGridNodes.length; i < len; i++) {
            var col = browseGridNodes[i];
            var cType = col.getAttribute('data-type-id') || '';
            var cName = (col.getAttribute('data-event-name') || '').trim().toLowerCase();
            var cDate = col.getAttribute('data-date') || '';

            var show = !((fType && cType !== fType)
                || (fName && cName !== fName)
                || (fDate && cDate < fDate));

            // Inline `!important` is the only thing that beats Fomantic UI's
            // `.ui.grid > .column { display: ... !important }` rule.
            if (show) {
                col.style.removeProperty('display');
                visible++;
                if (!col.hasAttribute('data-cancelled')) actionable++;
            } else {
                col.style.setProperty('display', 'none', 'important');
            }
        }

        $browseNoResults.toggle(visible === 0 && browseHasGrid);
        if ($browseBadge.length) {
            $browseBadge.text(actionable);
            $browseBadge.toggle(actionable > 0);
        }
    }

    function cascadeNameOptions() {
        // When a Type is picked, disable Name options that don't match.
        var fType = ($('#browse_type_filter').val() || '').toString();
        var $name = $('#browse_name_filter');
        $name.find('option').each(function() {
            var $opt = $(this);
            if ($opt.val() === '') { return; }
            var optType = ($opt.attr('data-type-id') || '').toString();
            $opt.prop('disabled', !!(fType && optType !== fType));
        });
        // Reset name if its current option is no longer enabled
        var curName = $name.val();
        if (curName) {
            var curOpt = $name.find('option[value="' + curName.replace(/"/g, '\\"') + '"]')[0];
            if (curOpt && curOpt.disabled) {
                $name.val('');
            }
        }
    }

    // Plain native change events fire reliably on plain <select>s.
    $('#browse_type_filter').on('change', function() {
        cascadeNameOptions();
        applyBrowseFilters();
    });
    $('#browse_name_filter').on('change', applyBrowseFilters);
    $('#browse_date_from').on('change', applyBrowseFilters);

    // Explicit Filter button — guaranteed trigger regardless of how the
    // user navigated the controls (touchscreen quirks, accessibility tools).
    $('#browse_apply_filter').on('click', applyBrowseFilters);

    $('#browse_clear_filter').on('click', function() {
        $('#browse_type_filter').val('');
        $('#browse_name_filter').find('option').prop('disabled', false);
        $('#browse_name_filter').val('');
        $('#browse_date_from').val($today);
        applyBrowseFilters();
    });

    // Tabs
    $('#my-sessions-tabs .item').on('click', function() {
        var tab = $(this).data('tab');
        $('#my-sessions-tabs .item').removeClass('active');
        $(this).addClass('active');
        $('.ui.bottom.attached.tab').removeClass('active');
        $('.ui.bottom.attached.tab[data-tab="' + tab + '"]').addClass('active');
        localStorage.setItem('my_sessions_tab', tab);
        if (tab === 'browse') {
            applyBrowseFilters();
        }
        // Re-init progress bars in the newly visible tab (gauges shown in both tabs).
        $('.ui.progress:visible').progress();
    });

    // Phase 71 : after a successful register/waitlist action, the server appends
    // `#tab=mine` to the redirect URL. We honor it, pulse the tab visually so
    // the user sees the new registration was placed in "Mes inscriptions",
    // and clear the fragment so a refresh doesn't keep auto-switching.
    var hashTab = null;
    var m = (window.location.hash || '').match(/tab=([a-z]+)/);
    if (m) {
        hashTab = m[1];
        history.replaceState(null, '', window.location.pathname + window.location.search);
    }

    // Restore tab from URL fragment (priority), else localStorage, else default ("mine" -- Phase 73).
    var savedTab = hashTab || localStorage.getItem('my_sessions_tab') || 'mine';
    if (savedTab !== 'mine') {
        $('#my-sessions-tabs .item[data-tab="' + savedTab + '"]').trigger('click');
    } else {
        $('.ui.progress:visible').progress();
    }
    if (hashTab === 'mine') {
        var $pulseTarget = $('#my-sessions-tabs .item[data-tab="mine"]');
        $pulseTarget.addClass('courses-tab-pulse');
        setTimeout(function() { $pulseTarget.removeClass('courses-tab-pulse'); }, 4000);
    }

    // "Trouver une séance" button from empty state
    $('#go-browse-btn').on('click', function() {
        $('#my-sessions-tabs .item[data-tab="browse"]').trigger('click');
    });

    // Séances passées repliables
    $('.courses-past-content').hide();
    $('.courses-past-toggle').on('click', function() {
        $(this).next('.courses-past-content').slideToggle(200);
        $(this).find('.dropdown.icon').toggleClass('rotated');
    });
});
</script>
{% endblock %}
